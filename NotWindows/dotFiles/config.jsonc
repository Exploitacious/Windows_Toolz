{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "parabola_small"
    },
    "display": {
        "separator": ": "
    },
    "modules": [
        "memory",
        {
            "type": "disk",
            "folders": "/"
        },
        "break",
        "uptime",
        "break",
        "localip",
        {
            "type": "publicip",
            "timeout": 2000
        }
    ]
}